/* ============================================
   DESIGN TOKENS
   ============================================ */
:root {
  --bg:         #080808;
  --border:     #1c1c1c;
  --border-mid: #2a2a2a;
  --text-hi:    #e8e4db;
  --text-mid:   #888880;
  --text-lo:    #444440;
  --accent:     #c4b48a;
  --sidebar-w:  240px;
  --font-serif: 'Cormorant Garamond', Georgia, serif;
  --font-sans:  'Inter', system-ui, sans-serif;
  --ease:       cubic-bezier(0.25, 0.1, 0.25, 1);
}

/* ============================================
   BASE
   ============================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text-hi);
  font-family: var(--font-sans);
  font-weight: 300;
  font-size: 14px;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}

img { display: block; }
a { color: inherit; text-decoration: none; }
button { background: none; border: none; cursor: pointer; font: inherit; color: inherit; }

/* ============================================
   LAYOUT
   ============================================ */
.site-wrapper { display: flex; min-height: 100vh; }

/* ============================================
   SIDEBAR
   ============================================ */
.sidebar {
  position: fixed;
  top: 0; left: 0;
  width: var(--sidebar-w);
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 48px 40px;
  border-right: 1px solid var(--border);
  background: var(--bg);
  z-index: 100;
}

.sidebar-monogram {
  font-family: var(--font-serif);
  font-size: 22px;
  font-weight: 400;
  letter-spacing: 0.08em;
  margin-bottom: 48px;
}

.sidebar-nav { display: flex; flex-direction: column; gap: 6px; }

.nav-item {
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--text-lo);
  text-align: left;
  padding: 6px 0;
  position: relative;
  transition: color 0.2s var(--ease);
}

.nav-item::after {
  content: '';
  position: absolute;
  left: 0; bottom: 4px;
  width: 0; height: 1px;
  background: var(--text-hi);
  transition: width 0.25s var(--ease);
}

.nav-item:hover { color: var(--text-mid); }
.nav-item:hover::after { width: 24px; }
.nav-item.active { color: var(--text-hi); }
.nav-item.active::after { width: 28px; }

.sidebar-bottom { display: flex; flex-direction: column; gap: 20px; }

.social-links { display: flex; gap: 16px; align-items: center; }
.social-links a { opacity: 0.4; transition: opacity 0.2s; }
.social-links a:hover { opacity: 1; }
.social-links img { width: 18px; height: 18px; filter: invert(1); }

.resume-btn {
  display: inline-block;
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--text-mid);
  border: 1px solid var(--border-mid);
  padding: 8px 14px;
  width: fit-content;
  transition: color 0.2s, border-color 0.2s;
}
.resume-btn:hover { color: var(--text-hi); border-color: var(--text-hi); }

.sidebar-copyright { font-size: 10px; letter-spacing: 0.08em; color: var(--text-lo); }

/* ============================================
   MAIN CONTENT
   ============================================ */
.main-content { margin-left: var(--sidebar-w); flex: 1; min-width: 0; }

/* ============================================
   HERO
   ============================================ */
.hero-section {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px;
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}

.hero-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 60px;
  max-width: 1000px;
}

.hero-text { flex: 1; min-width: 0; }

.hero-name {
  font-family: var(--font-serif);
  font-weight: 300;
  font-size: clamp(64px, 7vw, 108px);
  line-height: 0.92;
  letter-spacing: -0.01em;
  display: flex;
  flex-direction: column;
  margin-bottom: 28px;
}
.hero-name span { display: block; }

.hero-title {
  font-size: 12px;
  letter-spacing: 0.22em;
  color: var(--text-mid);
  text-transform: uppercase;
  margin-bottom: 28px;
}

.hero-rule { width: 40px; height: 1px; background: var(--border-mid); margin-bottom: 28px; }

.hero-desc { font-size: 14px; line-height: 1.8; color: var(--text-mid); max-width: 420px; }

.hero-photo-wrap { flex-shrink: 0; position: relative; }

.hero-photo {
  width: 260px;
  height: 340px;
  object-fit: cover;
  object-position: center top;
  filter: grayscale(15%) contrast(1.05);
  display: block;
}

.hero-photo-frame {
  position: absolute;
  top: 14px; left: 14px; right: -14px; bottom: -14px;
  border: 1px solid var(--border-mid);
  pointer-events: none;
  z-index: -1;
}

.hero-scroll {
  position: absolute;
  bottom: 40px; left: 80px;
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--text-lo);
}

.hero-scroll-line {
  width: 48px;
  height: 1px;
  background: var(--text-lo);
  animation: scroll-pulse 2s ease-in-out infinite;
}

@keyframes scroll-pulse {
  0%, 100% { opacity: 0.3; width: 48px; }
  50%       { opacity: 1;   width: 64px; }
}

/* ============================================
   CONTENT SECTIONS
   ============================================ */
.content-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}

.section-header { display: flex; align-items: center; gap: 24px; margin-bottom: 40px; }

.section-label {
  font-size: 10px;
  letter-spacing: 0.28em;
  color: var(--text-lo);
  text-transform: uppercase;
  white-space: nowrap;
}

.section-line { height: 1px; background: var(--border); max-width: 80px; flex: 1; }

.section-intro {
  font-size: 13px;
  color: var(--text-mid);
  max-width: 560px;
  line-height: 1.8;
  margin-bottom: 40px;
}

/* ============================================
   EXPERIENCE
   ============================================ */
.experience-list { display: flex; flex-direction: column; max-width: 820px; }

.exp-item {
  display: grid;
  grid-template-columns: 56px 1fr;
  gap: 28px;
  align-items: flex-start;
  padding: 32px 0;
  border-bottom: 1px solid var(--border);
  border-left: 2px solid transparent;
  padding-left: 0;
  transition: border-color 0.25s var(--ease);
}
.exp-item:first-child { border-top: 1px solid var(--border); }
.exp-item:hover { border-left-color: var(--border-mid); padding-left: 12px; }

.exp-logo-wrap { padding-top: 3px; }

.exp-logo {
  width: 40px; height: 40px;
  object-fit: contain;
  filter: grayscale(100%) brightness(0.85);
  opacity: 0.6;
  transition: opacity 0.25s var(--ease), filter 0.25s var(--ease);
}
.exp-item:hover .exp-logo { opacity: 1; filter: grayscale(0%); }

.exp-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 5px;
  flex-wrap: wrap;
}

.exp-role { font-size: 15px; font-weight: 400; letter-spacing: -0.01em; }

.exp-period { font-size: 11px; letter-spacing: 0.06em; color: var(--text-lo); white-space: nowrap; }

.exp-company-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }

.exp-company { font-size: 13px; color: var(--text-mid); }

.exp-badge {
  font-size: 9px;
  letter-spacing: 0.12em;
  color: var(--accent);
  border: 1px solid var(--accent);
  padding: 2px 6px;
  opacity: 0.8;
}

.exp-location { font-size: 11px; letter-spacing: 0.06em; color: var(--text-lo); }

.exp-highlights {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 14px;
}

.exp-highlights li {
  font-size: 13px;
  color: var(--text-mid);
  line-height: 1.75;
  padding-left: 16px;
  position: relative;
}
.exp-highlights li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--text-lo);
  font-size: 11px;
  top: 3px;
}

.exp-tools { display: flex; flex-wrap: wrap; gap: 6px; }

.tool-tag {
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--text-lo);
  border: 1px solid var(--border-mid);
  padding: 3px 9px;
  transition: color 0.2s, border-color 0.2s;
}
.exp-item:hover .tool-tag { color: var(--text-mid); border-color: var(--text-lo); }

/* ============================================
   EDUCATION
   ============================================ */
.education-list { display: flex; flex-direction: column; max-width: 820px; }

.edu-item {
  display: grid;
  grid-template-columns: 56px 1fr;
  gap: 28px;
  align-items: center;
  padding: 28px 0;
  border-bottom: 1px solid var(--border);
}
.edu-item:first-child { border-top: 1px solid var(--border); }

.edu-logo {
  width: 40px; height: 40px;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.6;
  transition: opacity 0.25s var(--ease), filter 0.25s var(--ease);
}
.edu-item:hover .edu-logo { opacity: 1; filter: grayscale(0%); }

.edu-school { font-size: 15px; font-weight: 400; margin-bottom: 3px; }

.edu-degree { font-size: 13px; color: var(--text-mid); }

.edu-spec { font-size: 11px; letter-spacing: 0.08em; color: var(--accent); opacity: 0.85; margin-top: 4px; }

.edu-period { font-size: 11px; letter-spacing: 0.06em; color: var(--text-lo); margin-top: 4px; }

/* ============================================
   PROJECTS
   ============================================ */
.projects-list { display: flex; flex-direction: column; max-width: 820px; }

.project-item {
  padding: 32px 0;
  border-bottom: 1px solid var(--border);
}
.project-item:first-child { border-top: 1px solid var(--border); }

.project-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 5px;
}

.project-name {
  font-size: 15px;
  font-weight: 400;
  letter-spacing: -0.01em;
  transition: color 0.2s;
}
.project-item:hover .project-name { color: var(--text-mid); }

.project-link {
  font-size: 11px;
  letter-spacing: 0.08em;
  color: var(--text-lo);
  white-space: nowrap;
  transition: color 0.2s;
}
.project-link:hover { color: var(--text-hi); }

.project-role {
  font-size: 11px;
  letter-spacing: 0.08em;
  color: var(--accent);
  opacity: 0.85;
  margin-bottom: 10px;
}

.project-desc { font-size: 13px; color: var(--text-mid); line-height: 1.8; max-width: 600px; }

/* ============================================
   FOOTER
   ============================================ */
.site-footer {
  padding: 40px 80px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.site-footer p { font-size: 11px; letter-spacing: 0.08em; color: var(--text-lo); }

.site-footer a { font-size: 11px; letter-spacing: 0.12em; color: var(--text-lo); transition: color 0.2s; }
.site-footer a:hover { color: var(--text-hi); }

/* ============================================
   MOBILE NAV
   ============================================ */
.mobile-nav {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 56px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  z-index: 200;
}

.mobile-monogram { font-family: var(--font-serif); font-size: 18px; letter-spacing: 0.1em; }

.mobile-nav-links { display: flex; gap: 20px; }

.mobile-nav-links button {
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--text-lo);
  transition: color 0.2s;
}
.mobile-nav-links button.active,
.mobile-nav-links button:hover { color: var(--text-hi); }

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 1024px) {
  :root { --sidebar-w: 200px; }
  .hero-section,
  .content-section { padding: 64px 48px; }
  .hero-photo { width: 200px; height: 260px; }
  .site-footer { padding: 32px 48px; }
}

@media (max-width: 768px) {
  .sidebar { display: none; }
  .mobile-nav { display: flex; }
  .main-content { margin-left: 0; padding-top: 56px; }

  .hero-section { padding: 48px 28px 72px; min-height: calc(100vh - 56px); }

  .hero-inner { flex-direction: column; gap: 0; }

  .hero-photo-wrap { display: none; }

  .hero-scroll { left: 28px; bottom: 28px; }

  .content-section { padding: 48px 24px; }

  .exp-item,
  .edu-item { grid-template-columns: 40px 1fr; gap: 16px; }

  .exp-header { flex-direction: column; gap: 2px; }

  .site-footer { padding: 32px 24px; flex-direction: column; gap: 8px; align-items: flex-start; }
}

/* ============================================
   SCROLL FADE-IN
   ============================================ */
.fade-in {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s var(--ease), transform 0.6s var(--ease);
}
.fade-in.visible { opacity: 1; transform: translateY(0); }
